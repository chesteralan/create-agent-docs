    {{/ne}}
  ClientApp -->|API Calls (JSON/HTTP)| APIBackend[{{backend}} Server]
    {{#ne database "None"}}
    APIBackend -->|Query/Mutation| Database[({{database}} Database)]
    {{/ne}}
  {{/eq}}
```

