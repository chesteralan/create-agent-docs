{
  "name": "create-agent-docs",
  "version": "1.0.2",
  "description": "CLI scaffolding tool to generate AI-ready documentation systems for software projects",
  "keywords": [
    "documentation",
    "ai",
    "agent",
    "scaffold",
    "cli",
    "nextjs",
    "react",
    "vue",
    "angular",
    "firebase",
    "cursor",
    "claude",
    "codex",
    "developer-tools"
  ],
  "license": "MIT",
  "homepage": "https://github.com/anomalyco/create-agent-docs#readme",
  "bugs": {
    "url": "https://github.com/anomalyco/create-agent-docs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/create-agent-docs.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "create-agent-docs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "yarn build && yarn test",
    "prepack": "yarn build",
    "build": "tsup && node scripts/copy-templates.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "handlebars": "^4.7.9",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}